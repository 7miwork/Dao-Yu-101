---
interface Props {
  size?: number;
  position?: {
    x: number;
    y: number;
    z: number;
  };
  rotation?: number;
}

const { 
  size = 1, 
  position = { x: 0, y: 0, z: 0 },
  rotation = 0 
} = Astro.props;

const baseSize = 25;
const houseWidth = baseSize * 1.0 * size;
const houseHeight = baseSize * 1.2 * size;
const houseDepth = baseSize * 0.8 * size;
---

<style>
  .voxel-house {
    position: absolute;
    transform-style: preserve-3d;
    transform: translate3d(
      calc(var(--x) * 1px), 
      calc(var(--y) * 1px), 
      calc(var(--z) * 1px)
    ) rotateY(calc(var(--rotation) * 1deg));
    transform-origin: center;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  .house-body {
    position: absolute;
    width: calc(var(--house-width) * 1px);
    height: calc(var(--house-height) * 1px);
    background: linear-gradient(
      to bottom,
      #D2B48C 0%,
      #C2A57B 50%,
      #A68B6A 100%
    );
    border: 2px solid #8B5E3C;
    border-radius: 2px;
    transform: translate3d(
      calc(var(--house-width) / -2 * 1px), 
      calc(var(--house-height) / -1 * 1px), 
      0
    );
    box-shadow: 
      3px 3px 6px rgba(0, 0, 0, 0.4),
      -3px 3px 6px rgba(255, 255, 255, 0.1);
  }

  .house-roof {
    position: absolute;
    width: calc(var(--house-width) * 1.1 * 1px);
    height: calc(var(--house-height) * 0.4 * 1px);
    background: linear-gradient(
      to bottom,
      #8B0000 0%,
      #B22222 100%
    );
    border: 2px solid #5C0000;
    border-radius: 2px;
    transform: translate3d(
      calc(var(--house-width) * -0.55 * 1px), 
      calc(var(--house-height) * -1.3 * 1px), 
      10px
    );
    box-shadow: 
      2px 2px 4px rgba(0, 0, 0, 0.3),
      -2px 2px 4px rgba(255, 255, 255, 0.1);
  }

  .house-door {
    position: absolute;
    width: calc(var(--house-width) * 0.3 * 1px);
    height: calc(var(--house-height) * 0.4 * 1px);
    background: #2F1B10;
    border: 1px solid #1A0F08;
    border-radius: 1px;
    transform: translate3d(
      calc(var(--house-width) * -0.15 * 1px), 
      calc(var(--house-height) * -0.6 * 1px), 
      5px
    );
    box-shadow: inset 2px 2px 4px rgba(0, 0, 0, 0.5);
  }

  .house-window {
    position: absolute;
    width: calc(var(--house-width) * 0.2 * 1px);
    height: calc(var(--house-height) * 0.2 * 1px);
    background: linear-gradient(
      to bottom,
      #87CEEB 0%,
      #4682B4 100%
    );
    border: 1px solid #1E3A5F;
    border-radius: 1px;
    box-shadow: inset 2px 2px 4px rgba(0, 0, 0, 0.3);
  }

  .house-window:nth-child(4) {
    transform: translate3d(
      calc(var(--house-width) * -0.35 * 1px), 
      calc(var(--house-height) * -0.8 * 1px), 
      5px
    );
  }

  .house-window:nth-child(5) {
    transform: translate3d(
      calc(var(--house-width) * 0.15 * 1px), 
      calc(var(--house-height) * -0.8 * 1px), 
      5px
    );
  }
</style>

<div 
  class="voxel-house"
  style="--x: {position.x}; --y: {position.y}; --z: {position.z}; --rotation: {rotation}; --house-width: {houseWidth}; --house-height: {houseHeight};"
>
  <div class="house-body"></div>
  <div class="house-roof"></div>
  <div class="house-door"></div>
  <div class="house-window"></div>
  <div class="house-window"></div>
</div>