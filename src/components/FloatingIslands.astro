<div class="floating-islands-container">
  <div class="island-layer layer-1">
    <div class="island island-a"></div>
    <div class="island island-b"></div>
  </div>
  
  <div class="island-layer layer-2">
    <div class="island island-c"></div>
    <div class="island island-d"></div>
  </div>
  
  <div class="island-layer layer-3">
    <div class="island island-e"></div>
    <div class="island island-f"></div>
  </div>
  
  <div class="island-layer layer-4">
    <div class="island island-g"></div>
  </div>
</div>

<style>
  .floating-islands-container {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 1;
  }

  .island-layer {
    position: absolute;
    width: 100%;
    height: 100%;
  }

  .island {
    position: absolute;
    background: linear-gradient(135deg, #2E7D32, #4CAF50);
    border-radius: 50% 50% 0 0;
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.4);
    animation: float 8s ease-in-out infinite;
    transform-origin: center bottom;
  }

  /* Layer 1 - Closest, fastest movement */
  .layer-1 {
    z-index: 4;
  }

  .island-a {
    width: 250px;
    height: 150px;
    top: 15%;
    left: 5%;
    animation-delay: 0s;
    animation-duration: 6s;
    background: linear-gradient(135deg, #1b5e20, #2e7d32);
  }

  .island-b {
    width: 200px;
    height: 120px;
    top: 25%;
    right: 10%;
    animation-delay: 2s;
    animation-duration: 7s;
    background: linear-gradient(135deg, #2e7d32, #4caf50);
  }

  /* Layer 2 - Medium distance, medium speed */
  .layer-2 {
    z-index: 3;
    opacity: 0.9;
  }

  .island-c {
    width: 180px;
    height: 110px;
    top: 45%;
    left: 15%;
    animation-delay: 1s;
    animation-duration: 9s;
    background: linear-gradient(135deg, #388e3c, #66bb6a);
  }

  .island-d {
    width: 220px;
    height: 130px;
    top: 55%;
    right: 20%;
    animation-delay: 3s;
    animation-duration: 8s;
    background: linear-gradient(135deg, #4caf50, #81c784);
  }

  /* Layer 3 - Farther, slower movement */
  .layer-3 {
    z-index: 2;
    opacity: 0.8;
  }

  .island-e {
    width: 160px;
    height: 100px;
    bottom: 20%;
    left: 10%;
    animation-delay: 4s;
    animation-duration: 10s;
    background: linear-gradient(135deg, #66bb6a, #a5d6a7);
  }

  .island-f {
    width: 190px;
    height: 115px;
    bottom: 30%;
    right: 15%;
    animation-delay: 5s;
    animation-duration: 11s;
    background: linear-gradient(135deg, #81c784, #c8e6c9);
  }

  /* Layer 4 - Background, slowest movement */
  .layer-4 {
    z-index: 1;
    opacity: 0.6;
  }

  .island-g {
    width: 300px;
    height: 180px;
    top: 65%;
    left: 50%;
    transform: translateX(-50%);
    animation-delay: 6s;
    animation-duration: 12s;
    background: linear-gradient(135deg, #a5d6a7, #e8f5e9);
  }

  @keyframes float {
    0%, 100% { 
      transform: translateY(0px) rotate(0deg);
    }
    50% { 
      transform: translateY(-30px) rotate(1deg);
    }
  }

  /* Add subtle floating animation variations */
  .island-a { animation-name: floatSlow; }
  .island-b { animation-name: floatMedium; }
  .island-c { animation-name: floatSlow; }
  .island-d { animation-name: floatFast; }
  .island-e { animation-name: floatMedium; }
  .island-f { animation-name: floatSlow; }
  .island-g { animation-name: floatVerySlow; }

  @keyframes floatFast {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(0.5deg); }
  }

  @keyframes floatMedium {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-25px) rotate(0.8deg); }
  }

  @keyframes floatSlow {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-35px) rotate(1.2deg); }
  }

  @keyframes floatVerySlow {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-40px) rotate(1.5deg); }
  }

  /* Add some voxel-style details */
  .island::before {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 10px;
    width: 60%;
    height: 15px;
    background: rgba(0, 0, 0, 0.2);
    border-radius: 50%;
    filter: blur(2px);
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .island {
      transform: scale(0.8);
    }
    
    .island-g {
      transform: translateX(-50%) scale(0.9);
    }
  }

  @media (max-width: 480px) {
    .island {
      transform: scale(0.6);
    }
    
    .island-g {
      transform: translateX(-50%) scale(0.7);
    }
  }
</style>