---
import VoxelIsland from './VoxelIsland.astro';

interface Props {
  variant?: 'foreground' | 'midground' | 'background';
}

const { variant = 'foreground' } = Astro.props;
---

<div class={`island-layer island-${variant} parallax-layer`} data-variant={variant} data-depth={variant === 'foreground' ? '1.0' : variant === 'midground' ? '0.5' : '0.2'}>
  {variant === 'foreground' && (
    <>
      <VoxelIsland id="island-1" x={-120} y={220} z={100} scale={1.3} className="foreground-island parallax" data-depth="1.0" includeDetails={true} />
      <VoxelIsland id="island-2" x={220} y={260} z={80} scale={1.1} className="foreground-island parallax" data-depth="1.0" includeDetails={true} />
    </>
  )}
  
  {variant === 'midground' && (
    <>
      <VoxelIsland id="island-3" x={-180} y={160} z={50} scale={0.95} className="midground-island parallax" data-depth="0.5" includeDetails={true} />
      <VoxelIsland id="island-4" x={80} y={190} z={40} scale={0.85} className="midground-island parallax" data-depth="0.5" includeDetails={true} />
      <VoxelIsland id="island-5" x={280} y={230} z={30} scale={0.75} className="midground-island parallax" data-depth="0.5" includeDetails={true} />
    </>
  )}
  
  {variant === 'background' && (
    <>
      <VoxelIsland id="island-6" x={-220} y={90} z={0} scale={0.65} className="background-island parallax" data-depth="0.2" includeDetails={false} />
      <VoxelIsland id="island-7" x={60} y={130} z={-20} scale={0.55} className="background-island parallax" data-depth="0.2" includeDetails={false} />
      <VoxelIsland id="island-8" x={320} y={110} z={-40} scale={0.45} className="background-island parallax" data-depth="0.2" includeDetails={false} />
    </>
  )}
</div>

<style>
  .island-layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  /* Layer-specific styles */
  .island-foreground {
    z-index: 4;
  }

  .island-midground {
    z-index: 3;
  }

  .island-background {
    z-index: 2;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .voxel-island {
      transform: scale(0.7);
    }
  }

  @media (max-width: 480px) {
    .voxel-island {
      transform: scale(0.5);
    }
  }
</style>

<script>
  import VoxelIsland from './VoxelIsland.astro';
</script>
