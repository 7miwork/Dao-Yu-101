---
interface Props {
  type: 'grass' | 'dirt' | 'sand';
  size?: number;
  className?: string;
}

const { type = 'grass', size = 40, className = '' } = Astro.props;
---

<div class="voxel-block {className}" style="--size: {size}px">
  <div class="voxel-top"></div>
  <div class="voxel-front"></div>
  <div class="voxel-side"></div>
</div>

<style>
  .voxel-block {
    position: relative;
    width: var(--size);
    height: var(--size);
    transform-style: preserve-3d;
    transform: rotateX(60deg) rotateZ(45deg);
  }

  .voxel-top {
    position: absolute;
    width: 100%;
    height: 100%;
    transform: rotateX(-90deg);
    border-radius: 4px 4px 0 0;
  }

  .voxel-front {
    position: absolute;
    width: 100%;
    height: 100%;
    transform: rotateY(90deg) rotateX(90deg);
    border-radius: 4px 0 0 4px;
  }

  .voxel-side {
    position: absolute;
    width: 100%;
    height: 100%;
    transform: rotateX(90deg);
    border-radius: 0 4px 4px 0;
  }

  /* Grass Block */
  .voxel-block[type="grass"] .voxel-top {
    background: linear-gradient(180deg, #4ade80 0%, #22c55e 100%);
    box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.1);
  }

  .voxel-block[type="grass"] .voxel-front {
    background: linear-gradient(180deg, #16a34a 0%, #15803d 100%);
    box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.2);
  }

  .voxel-block[type="grass"] .voxel-side {
    background: linear-gradient(180deg, #16a34a 0%, #15803d 100%);
    box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.2);
  }

  /* Dirt Block */
  .voxel-block[type="dirt"] .voxel-top {
    background: linear-gradient(180deg, #8b5a2b 0%, #654321 100%);
    box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.2);
  }

  .voxel-block[type="dirt"] .voxel-front {
    background: linear-gradient(180deg, #5d4037 0%, #4e342e 100%);
    box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.3);
  }

  .voxel-block[type="dirt"] .voxel-side {
    background: linear-gradient(180deg, #5d4037 0%, #4e342e 100%);
    box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.3);
  }

  /* Sand Block */
  .voxel-block[type="sand"] .voxel-top {
    background: linear-gradient(180deg, #fbbf24 0%, #f59e0b 100%);
    box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.1);
  }

  .voxel-block[type="sand"] .voxel-front {
    background: linear-gradient(180deg, #d97706 0%, #b45309 100%);
    box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.2);
  }

  .voxel-block[type="sand"] .voxel-side {
    background: linear-gradient(180deg, #d97706 0%, #b45309 100%);
    box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.2);
  }
</style>