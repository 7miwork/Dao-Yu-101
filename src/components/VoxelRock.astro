---
interface Props {
  size?: number;
  position?: {
    x: number;
    y: number;
    z: number;
  };
  rotation?: number;
}

const { 
  size = 1, 
  position = { x: 0, y: 0, z: 0 },
  rotation = 0 
} = Astro.props;

const baseSize = 15;
const rockWidth = baseSize * 1.2 * size;
const rockHeight = baseSize * 0.8 * size;
const rockDepth = baseSize * 1.0 * size;
---

<style>
  .voxel-rock {
    position: absolute;
    transform-style: preserve-3d;
    transform: translate3d(
      calc(var(--x) * 1px), 
      calc(var(--y) * 1px), 
      calc(var(--z) * 1px)
    ) rotateY(calc(var(--rotation) * 1deg));
    transform-origin: center;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  .rock-body {
    position: absolute;
    width: calc(var(--rock-width) * 1px);
    height: calc(var(--rock-height) * 1px);
    background: linear-gradient(
      to bottom,
      #8D8D8D 0%,
      #6E6E6E 50%,
      #4F4F4F 100%
    );
    border: 2px solid #3A3A3A;
    border-radius: 6px;
    transform: translate3d(
      calc(var(--rock-width) / -2 * 1px), 
      calc(var(--rock-height) / -2 * 1px), 
      0
    );
    box-shadow: 
      3px 3px 6px rgba(0, 0, 0, 0.4),
      -3px 3px 6px rgba(255, 255, 255, 0.1);
  }

  .rock-body::before {
    content: '';
    position: absolute;
    top: 2px;
    left: 2px;
    right: 2px;
    bottom: 2px;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.1) 0%,
      transparent 50%,
      rgba(0, 0, 0, 0.1) 100%
    );
    border-radius: 4px;
  }

  .rock-detail {
    position: absolute;
    background: #5A5A5A;
    border: 1px solid #3A3A3A;
    border-radius: 2px;
    box-shadow: 1px 1px 2px rgba(0, 0, 0, 0.3);
  }

  .rock-detail:nth-child(2) {
    width: calc(var(--rock-width) * 0.3 * 1px);
    height: calc(var(--rock-height) * 0.2 * 1px);
    transform: translate3d(
      calc(var(--rock-width) * 0.2 * 1px), 
      calc(var(--rock-height) * -0.3 * 1px), 
      5px
    );
  }

  .rock-detail:nth-child(3) {
    width: calc(var(--rock-width) * 0.25 * 1px);
    height: calc(var(--rock-height) * 0.15 * 1px);
    transform: translate3d(
      calc(var(--rock-width) * -0.3 * 1px), 
      calc(var(--rock-height) * 0.2 * 1px), 
      5px
    );
  }

  .rock-detail:nth-child(4) {
    width: calc(var(--rock-width) * 0.2 * 1px);
    height: calc(var(--rock-height) * 0.25 * 1px);
    transform: translate3d(
      calc(var(--rock-width) * 0.3 * 1px), 
      calc(var(--rock-height) * 0.3 * 1px), 
      5px
    );
  }
</style>

<div 
  class="voxel-rock"
  style="--x: {position.x}; --y: {position.y}; --z: {position.z}; --rotation: {rotation}; --rock-width: {rockWidth}; --rock-height: {rockHeight};"
>
  <div class="rock-body"></div>
  <div class="rock-detail"></div>
  <div class="rock-detail"></div>
  <div class="rock-detail"></div>
</div>