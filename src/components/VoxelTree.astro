---
interface Props {
  size?: number;
  position?: {
    x: number;
    y: number;
    z: number;
  };
  rotation?: number;
}

const { 
  size = 1, 
  position = { x: 0, y: 0, z: 0 },
  rotation = 0 
} = Astro.props;

const baseSize = 20;
const trunkHeight = baseSize * 2 * size;
const trunkWidth = baseSize * 0.6 * size;
const leafSize = baseSize * 1.2 * size;
---

<style>
  .voxel-tree {
    position: absolute;
    transform-style: preserve-3d;
    transform: translate3d(
      calc(var(--x) * 1px), 
      calc(var(--y) * 1px), 
      calc(var(--z) * 1px)
    ) rotateY(calc(var(--rotation) * 1deg));
    transform-origin: center;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  .tree-trunk {
    position: absolute;
    width: calc(var(--trunk-width) * 1px);
    height: calc(var(--trunk-height) * 1px);
    background: linear-gradient(
      to bottom,
      #8B4513 0%,
      #5D4037 50%,
      #3E2723 100%
    );
    border: 2px solid #2E1B14;
    border-radius: 2px;
    transform: translate3d(
      calc(var(--trunk-width) / -2 * 1px), 
      calc(var(--trunk-height) / -1 * 1px), 
      0
    );
    box-shadow: 
      2px 2px 4px rgba(0, 0, 0, 0.3),
      -2px 2px 4px rgba(255, 255, 255, 0.1);
  }

  .tree-foliage {
    position: absolute;
    transform: translate3d(
      calc(var(--leaf-size) / -2 * 1px), 
      calc(var(--trunk-height) * -1.2 * 1px), 
      10px
    );
    transform-style: preserve-3d;
  }

  .leaf-block {
    position: absolute;
    width: calc(var(--leaf-size) * 1px);
    height: calc(var(--leaf-size) * 1px);
    background: #4CAF50;
    border: 2px solid #2E7D32;
    border-radius: 2px;
    box-shadow: 
      2px 2px 4px rgba(0, 0, 0, 0.3),
      -2px 2px 4px rgba(255, 255, 255, 0.1);
  }

  /* 3x3 leaf cube structure */
  .leaf-center { transform: translate3d(0, 0, 0); }
  .leaf-left { transform: translate3d(calc(var(--leaf-size) * -1.2px), 0, 0); }
  .leaf-right { transform: translate3d(calc(var(--leaf-size) * 1.2px), 0, 0); }
  .leaf-front { transform: translate3d(0, calc(var(--leaf-size) * -1.2px), 0); }
  .leaf-back { transform: translate3d(0, calc(var(--leaf-size) * 1.2px), 0); }
  
  .leaf-top { transform: translate3d(0, 0, calc(var(--leaf-size) * 1.2px)); }
  .leaf-top-left { transform: translate3d(calc(var(--leaf-size) * -1.2px), 0, calc(var(--leaf-size) * 1.2px)); }
  .leaf-top-right { transform: translate3d(calc(var(--leaf-size) * 1.2px), 0, calc(var(--leaf-size) * 1.2px)); }
</style>

<div 
  class="voxel-tree"
  style="--x: {position.x}; --y: {position.y}; --z: {position.z}; --rotation: {rotation}; --trunk-width: {trunkWidth}; --trunk-height: {trunkHeight}; --leaf-size: {leafSize};"
>
  <div class="tree-trunk"></div>
  <div class="tree-foliage">
    <!-- 3x3 leaf cube structure -->
    <div class="leaf-block leaf-center"></div>
    <div class="leaf-block leaf-left"></div>
    <div class="leaf-block leaf-right"></div>
    <div class="leaf-block leaf-front"></div>
    <div class="leaf-block leaf-back"></div>
    <div class="leaf-block leaf-top"></div>
    <div class="leaf-block leaf-top-left"></div>
    <div class="leaf-block leaf-top-right"></div>
  </div>
</div>
