---
import LanguageSwitcher from './LanguageSwitcher.astro';
---

<header class="navbar">
  <div class="container">
    <div class="logo">
      <h1>Dao-Yu-101</h1>
    </div>
    <nav class="nav-menu">
      <button class="nav-btn game-btn">Store</button>
      <button class="nav-btn game-btn">Login</button>
      <button class="nav-btn game-btn">Register</button>
      <button class="nav-btn">About</button>
      <button class="nav-btn">FAQ</button>
    </nav>
    <div class="nav-actions">
      <LanguageSwitcher />
    </div>
  </div>
</header>

<style>
  .navbar {
    background: linear-gradient(180deg, rgba(255,255,255,0.95), rgba(255,255,255,0.8));
    backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo h1 {
    margin: 0;
    font-size: 1.5rem;
    color: #2c3e50;
    text-shadow: 2px 2px 0px rgba(255, 255, 255, 0.5);
  }

  .nav-menu {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .nav-btn {
    background: linear-gradient(135deg, #3498db, #2980b9);
    color: white;
    border: none;
    padding: 0.5rem 1rem;
    border-radius: 25px;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.3s ease;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }

  .nav-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
    background: linear-gradient(135deg, #2980b9, #3498db);
  }

  .game-btn {
    background: linear-gradient(135deg, #e74c3c, #c0392b);
    box-shadow: 0 6px 15px rgba(231, 76, 60, 0.4);
    border: 2px solid rgba(255, 255, 255, 0.3);
    text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.3);
  }

  .game-btn:hover {
    transform: translateY(-3px) scale(1.05);
    box-shadow: 0 10px 25px rgba(231, 76, 60, 0.6);
    background: linear-gradient(135deg, #c0392b, #e74c3c);
    border-color: rgba(255, 255, 255, 0.5);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  @media (max-width: 768px) {
    .container {
      flex-direction: column;
      gap: 1rem;
    }

    .nav-menu {
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>