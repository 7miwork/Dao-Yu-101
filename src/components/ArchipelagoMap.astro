---
// ArchipelagoMap component
// Visual representation of the learning structure
---

<div class="archipelago-map">
  <div class="container">
    <h2 class="section-title">Programming Archipelago</h2>
    <p class="section-description">
      The first learning world of Dao-Yu-101 focuses on programming fundamentals using Minecraft Education.
      Students learn block-based coding through interactive lessons built with Minecraft MakeCode.
    </p>
    
    <div class="island-container">
      <div class="archipelago-island">
        <div class="island-grass"></div>
        <div class="island-dirt layer1"></div>
        <div class="island-dirt layer2"></div>
        <div class="island-dirt layer3"></div>
        <div class="island-tree"></div>
        <div class="island-name">
          Minecraft MakeCode Island
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .archipelago-map {
    text-align: center;
    padding: 80px 20px;
    background: linear-gradient(#E6F6FF, #B8E4FF);
    position: relative;
    overflow: hidden;
  }
  
  .container {
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .section-title {
    font-size: 2.5rem;
    font-weight: 800;
    text-align: center;
    margin-bottom: 16px;
    color: #2c3e50;
    letter-spacing: -0.02em;
  }
  
  .section-description {
    font-size: 1.2rem;
    text-align: center;
    color: #666;
    margin-bottom: 60px;
    line-height: 1.6;
  }
  
  .island-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 200px;
  }
  
  .archipelago-island {
    position: relative;
    margin: 80px auto;
    filter: drop-shadow(0 10px 20px rgba(0,0,0,0.25));
  }
  
  .island-grass {
    width: 220px;
    height: 28px;
    background: linear-gradient(#7ED957, #5FAE3E);
    border-radius: 6px 6px 0 0;
    margin: auto;
  }
  
  .island-dirt.layer1 {
    width: 240px;
    height: 40px;
    background: #8B5A2B;
    margin: auto;
  }
  
  .island-dirt.layer2 {
    width: 180px;
    height: 30px;
    background: #7A4A22;
    margin: auto;
  }
  
  .island-dirt.layer3 {
    width: 120px;
    height: 24px;
    background: #6A3D1A;
    margin: auto;
    border-radius: 0 0 10px 10px;
  }
  
  .island-tree {
    width: 20px;
    height: 40px;
    background: #5A3A1A;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    bottom: 70px;
  }
  
  .island-tree::after {
    content: "";
    width: 40px;
    height: 40px;
    background: #3FAE3A;
    position: absolute;
    bottom: 30px;
    left: -10px;
    border-radius: 6px;
  }
  
  .island-name {
    margin-top: 16px;
    font-weight: bold;
    text-align: center;
  }
  
  /* Responsive styles */
  @media (max-width: 768px) {
    .section-title {
      font-size: 2rem;
    }
    
    .section-description {
      font-size: 1.1rem;
    }
    
    .archipelago-island {
      transform: scale(0.85);
    }
  }
  
  @media (max-width: 480px) {
    .section-title {
      font-size: 1.75rem;
    }
    
    .section-description {
      font-size: 1rem;
    }
    
    .archipelago-island {
      transform: scale(0.75);
    }
  }
</style>
