---
// ArchipelagoMap component
// Visual representation of the learning structure
---

<div class="archipelago-map">
  <div class="container">
    <h2 class="section-title">Programming Archipelago</h2>
    <p class="section-description">
      The first learning world of Dao-Yu-101 focuses on programming fundamentals using Minecraft Education.
      Students learn block-based coding through interactive lessons built with Minecraft MakeCode.
    </p>
    
    <div class="island-container">
      <div class="island">
        <div class="grass"></div>
        <div class="dirt"></div>
        <div class="island-label">
          Minecraft MakeCode
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .archipelago-map {
    text-align: center;
    padding: 80px 20px;
    background: linear-gradient(#E6F6FF, #B8E4FF);
    position: relative;
    overflow: hidden;
  }
  
  .container {
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .section-title {
    font-size: 2.5rem;
    font-weight: 800;
    text-align: center;
    margin-bottom: 16px;
    color: #2c3e50;
    letter-spacing: -0.02em;
  }
  
  .section-description {
    font-size: 1.2rem;
    text-align: center;
    color: #666;
    margin-bottom: 60px;
    line-height: 1.6;
  }
  
  .island-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 200px;
  }
  
  .island {
    width: 220px;
    margin: 60px auto;
    position: relative;
  }
  
  .grass {
    height: 24px;
    background: #7ED957;
    border-radius: 8px 8px 0 0;
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
  }
  
  .dirt {
    height: 60px;
    background: #8B5A2B;
    border-radius: 0 0 10px 10px;
    box-shadow: 0 6px 12px rgba(0,0,0,0.2);
  }
  
  .island-label {
    margin-top: 10px;
    text-align: center;
    font-weight: bold;
    font-size: 1.1rem;
    color: #2c3e50;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  
  /* Responsive styles */
  @media (max-width: 768px) {
    .section-title {
      font-size: 2rem;
    }
    
    .section-description {
      font-size: 1.1rem;
    }
    
    .island {
      transform: scale(0.8);
    }
  }
  
  @media (max-width: 480px) {
    .section-title {
      font-size: 1.75rem;
    }
    
    .section-description {
      font-size: 1rem;
    }
    
    .island {
      transform: scale(0.7);
    }
  }
</style>
