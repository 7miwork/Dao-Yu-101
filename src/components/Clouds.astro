---
interface Props {
  variant?: 'layer1' | 'layer2' | 'layer3';
}

const { variant = 'layer1' } = Astro.props;
---

<div class={`clouds-layer cloud-${variant}`}>
  {variant === 'layer1' && (
    <>
      <div class="block-cloud cloud-layer1" style="--delay: 0">
        <div class="cloud-block"></div>
        <div class="cloud-block"></div>
        <div class="cloud-block"></div>
        <div class="cloud-block"></div>
      </div>
      <div class="block-cloud cloud-layer1" style="--delay: 30">
        <div class="cloud-block"></div>
        <div class="cloud-block"></div>
        <div class="cloud-block"></div>
      </div>
      <div class="block-cloud cloud-layer1" style="--delay: 60">
        <div class="cloud-block"></div>
        <div class="cloud-block"></div>
        <div class="cloud-block"></div>
        <div class="cloud-block"></div>
        <div class="cloud-block"></div>
      </div>
    </>
  )}
  
  {variant === 'layer2' && (
    <>
      <div class="block-cloud cloud-layer2" style="--delay: 15">
        <div class="cloud-block"></div>
        <div class="cloud-block"></div>
        <div class="cloud-block"></div>
      </div>
      <div class="block-cloud cloud-layer2" style="--delay: 45">
        <div class="cloud-block"></div>
        <div class="cloud-block"></div>
        <div class="cloud-block"></div>
        <div class="cloud-block"></div>
      </div>
      <div class="block-cloud cloud-layer2" style="--delay: 75">
        <div class="cloud-block"></div>
        <div class="cloud-block"></div>
      </div>
    </>
  )}
  
  {variant === 'layer3' && (
    <>
      <div class="block-cloud cloud-layer3" style="--delay: 10">
        <div class="cloud-block"></div>
        <div class="cloud-block"></div>
        <div class="cloud-block"></div>
        <div class="cloud-block"></div>
      </div>
      <div class="block-cloud cloud-layer3" style="--delay: 50">
        <div class="cloud-block"></div>
        <div class="cloud-block"></div>
      </div>
      <div class="block-cloud cloud-layer3" style="--delay: 80">
        <div class="cloud-block"></div>
        <div class="cloud-block"></div>
        <div class="cloud-block"></div>
      </div>
    </>
  )}
</div>

<style>
  .clouds-layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  .block-cloud {
    position: absolute;
    opacity: 0.9;
  }

  .cloud-block {
    position: absolute;
    width: 40px;
    height: 40px;
    background: #FFFFFF;
    border: 1px solid #E0E0E0;
    border-radius: 4px;
    box-shadow: 2px 2px 4px rgba(0, 0, 0, 0.1);
  }

  /* Cloud formations */
  .block-cloud:nth-child(1) {
    top: 10%;
    left: -200px;
  }
  
  .block-cloud:nth-child(1) .cloud-block:nth-child(1) { transform: translate(0, 0); }
  .block-cloud:nth-child(1) .cloud-block:nth-child(2) { transform: translate(30px, 0); }
  .block-cloud:nth-child(1) .cloud-block:nth-child(3) { transform: translate(15px, -20px); }
  .block-cloud:nth-child(1) .cloud-block:nth-child(4) { transform: translate(45px, -20px); }

  .block-cloud:nth-child(2) {
    top: 30%;
    left: 100%;
  }
  
  .block-cloud:nth-child(2) .cloud-block:nth-child(1) { transform: translate(0, 0); }
  .block-cloud:nth-child(2) .cloud-block:nth-child(2) { transform: translate(30px, 0); }
  .block-cloud:nth-child(2) .cloud-block:nth-child(3) { transform: translate(15px, -20px); }

  .block-cloud:nth-child(3) {
    top: 50%;
    left: -250px;
  }
  
  .block-cloud:nth-child(3) .cloud-block:nth-child(1) { transform: translate(0, 0); }
  .block-cloud:nth-child(3) .cloud-block:nth-child(2) { transform: translate(30px, 0); }
  .block-cloud:nth-child(3) .cloud-block:nth-child(3) { transform: translate(60px, 0); }
  .block-cloud:nth-child(3) .cloud-block:nth-child(4) { transform: translate(15px, -20px); }
  .block-cloud:nth-child(3) .cloud-block:nth-child(5) { transform: translate(45px, -20px); }

  .block-cloud:nth-child(4) {
    top: 20%;
    left: 120%;
  }
  
  .block-cloud:nth-child(4) .cloud-block:nth-child(1) { transform: translate(0, 0); }
  .block-cloud:nth-child(4) .cloud-block:nth-child(2) { transform: translate(30px, 0); }
  .block-cloud:nth-child(4) .cloud-block:nth-child(3) { transform: translate(15px, -20px); }

  .block-cloud:nth-child(5) {
    top: 40%;
    left: -220px;
  }
  
  .block-cloud:nth-child(5) .cloud-block:nth-child(1) { transform: translate(0, 0); }
  .block-cloud:nth-child(5) .cloud-block:nth-child(2) { transform: translate(30px, 0); }

  .block-cloud:nth-child(6) {
    top: 60%;
    left: 110%;
  }
  
  .block-cloud:nth-child(6) .cloud-block:nth-child(1) { transform: translate(0, 0); }
  .block-cloud:nth-child(6) .cloud-block:nth-child(2) { transform: translate(30px, 0); }
  .block-cloud:nth-child(6) .cloud-block:nth-child(3) { transform: translate(15px, -20px); }

  /* Layer-specific styles */
  .cloud-layer1 {
    z-index: 1;
    opacity: 0.4;
    animation: float 90s linear infinite;
  }

  .cloud-layer2 {
    z-index: 2;
    opacity: 0.6;
    animation: float 120s linear infinite;
  }

  .cloud-layer3 {
    z-index: 3;
    opacity: 0.8;
    animation: float 150s linear infinite;
  }

  @keyframes float {
    0% { transform: translateX(-100px); }
    100% { transform: translateX(100vw); }
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .cloud-block {
      width: 30px;
      height: 30px;
    }
    
    .block-cloud:nth-child(1) { top: 15%; }
    .block-cloud:nth-child(2) { top: 35%; }
    .block-cloud:nth-child(3) { top: 55%; }
    .block-cloud:nth-child(4) { top: 25%; }
    .block-cloud:nth-child(5) { top: 45%; }
    .block-cloud:nth-child(6) { top: 65%; }
  }

  @media (max-width: 480px) {
    .cloud-block {
      width: 25px;
      height: 25px;
    }
    
    .block-cloud:nth-child(1) { top: 20%; }
    .block-cloud:nth-child(2) { top: 40%; }
    .block-cloud:nth-child(3) { top: 60%; }
    .block-cloud:nth-child(4) { top: 30%; }
    .block-cloud:nth-child(5) { top: 50%; }
    .block-cloud:nth-child(6) { top: 70%; }
  }
</style>