---
interface Props {
  className?: string;
}

const { className = '' } = Astro.props;
---

<div class={`ocean {className}`}>
  <div class="ocean-wave"></div>
  <div class="ocean-wave wave-2"></div>
  <div class="ocean-wave wave-3"></div>
</div>

<style>
  .ocean {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 40%;
    background: linear-gradient(180deg, #3b82f6 0%, #1e3a8a 100%);
    overflow: hidden;
    z-index: 1;
  }

  .ocean-wave {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 200%;
    height: 100px;
    background: linear-gradient(180deg, rgba(59, 130, 246, 0.6) 0%, rgba(30, 58, 138, 0.3) 100%);
    border-radius: 50%;
    animation: wave 15s ease-in-out infinite;
    opacity: 0.8;
  }

  .ocean-wave.wave-2 {
    bottom: 20px;
    height: 80px;
    animation: wave 12s ease-in-out infinite reverse;
    opacity: 0.6;
  }

  .ocean-wave.wave-3 {
    bottom: 40px;
    height: 60px;
    animation: wave 18s ease-in-out infinite;
    opacity: 0.4;
  }

  @keyframes wave {
    0% {
      transform: translateX(-100px);
    }
    50% {
      transform: translateX(100px);
    }
    100% {
      transform: translateX(-100px);
    }
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .ocean {
      height: 35%;
    }
    
    .ocean-wave {
      height: 80px;
    }
    
    .ocean-wave.wave-2 {
      bottom: 15px;
      height: 60px;
    }
    
    .ocean-wave.wave-3 {
      bottom: 30px;
      height: 40px;
    }
  }

  @media (max-width: 480px) {
    .ocean {
      height: 30%;
    }
    
    .ocean-wave {
      height: 60px;
    }
    
    .ocean-wave.wave-2 {
      bottom: 10px;
      height: 40px;
    }
    
    .ocean-wave.wave-3 {
      bottom: 20px;
      height: 30px;
    }
  }
</style>