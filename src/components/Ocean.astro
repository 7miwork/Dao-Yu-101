---
// Ocean component for the hero section
---

<div class="ocean">
  <div class="wave"></div>
  <div class="wave wave2"></div>
  <div class="wave wave3"></div>
</div>

<style>
  .ocean {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 40%;
    z-index: 1;
    overflow: hidden;
  }

  .wave {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, #e3f2fd 0%, #bbdefb 50%, #90caf9 100%);
    opacity: 0.8;
    animation: wave 20s ease-in-out infinite;
  }

  .wave2 {
    animation: wave 25s ease-in-out infinite reverse;
    opacity: 0.6;
    background: linear-gradient(180deg, #bbdefb 0%, #90caf9 50%, #64b5f6 100%);
  }

  .wave3 {
    animation: wave 30s ease-in-out infinite;
    opacity: 0.4;
    background: linear-gradient(180deg, #90caf9 0%, #64b5f6 50%, #42a5f5 100%);
  }

  @keyframes wave {
    0% { transform: translateX(0); }
    50% { transform: translateX(-20px); }
    100% { transform: translateX(0); }
  }
</style>