---
import MainIsland from './MainIsland.astro';
import VoxelTree from './VoxelTree.astro';
import Clouds from './Clouds.astro';
import Ocean from './Ocean.astro';
import GameButton from './GameButton.astro';
---

<section class="hero-container">
  <!-- Sky Background -->
  <div class="sky-background"></div>

  <!-- Clouds Layer -->
  <div class="clouds-container">
    <Clouds variant="layer1" />
    <Clouds variant="layer2" />
    <Clouds variant="layer3" />
  </div>

  <!-- Main Island -->
  <div class="main-island-container">
    <MainIsland>
      <VoxelTree size={1.2} />
    </MainIsland>
  </div>

  <!-- Ocean Layer -->
  <Ocean />

  <!-- Hero Content -->
  <div class="hero-content">
    <h1 class="hero-title">DAO-YU-101</h1>
    <p class="hero-subtitle">Discover your island adventure</p>
    
    <div class="hero-buttons">
      <GameButton label="Store" href="/store" />
      <GameButton label="Login" href="/login" variant="secondary" />
      <GameButton label="Register" href="/register" variant="secondary" />
    </div>
  </div>
</section>

<style>
  /* Import hero styles */
  @import '../styles/hero.css';

  /* Main Island Container */
  .main-island-container {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 6;
    pointer-events: none;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .main-island-container {
      top: 45%;
    }
  }

  @media (max-width: 480px) {
    .main-island-container {
      top: 40%;
    }
  }
</style>