---
import FloatingIslands from './FloatingIslands.astro';
import Clouds from './Clouds.astro';
import GameButton from './GameButton.astro';
---

<section class="hero-container">
  <!-- Clouds Layer -->
  <div class="clouds-container">
    <Clouds variant="slow" />
    <Clouds variant="medium" />
  </div>

  <!-- Floating Islands Layer -->
  <div class="islands-container">
    <FloatingIslands variant="background" />
    <FloatingIslands variant="midground" />
    <FloatingIslands variant="foreground" />
  </div>

  <!-- Ocean Waves -->
  <div class="ocean-waves">
    <div class="wave"></div>
  </div>

  <!-- Hero Content -->
  <div class="hero-content">
    <h1 class="hero-title">DAO-YU-101</h1>
    <p class="hero-subtitle">Discover your island adventure</p>
    
    <div class="hero-buttons">
      <GameButton label="Store" />
      <GameButton label="Login" variant="secondary" />
      <GameButton label="Register" variant="secondary" />
    </div>
  </div>
</section>

<style>
  /* Import hero styles */
  @import '../styles/hero.css';
</style>