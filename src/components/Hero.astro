---
import FloatingIslands from './FloatingIslands.astro';
import Clouds from './Clouds.astro';
import Ocean from './Ocean.astro';
import GameButton from './GameButton.astro';
---

<section class="hero-container">
  <!-- Sky Background -->
  <div class="sky-background"></div>

  <!-- Clouds Layer -->
  <div class="clouds-container">
    <Clouds variant="layer1" />
    <Clouds variant="layer2" />
    <Clouds variant="layer3" />
  </div>

  <!-- Floating Islands Layer -->
  <div class="islands-container" id="islands-container">
    <FloatingIslands variant="background" />
    <FloatingIslands variant="midground" />
    <FloatingIslands variant="foreground" />
  </div>

  <!-- Ocean Layer -->
  <Ocean />

  <!-- Hero Content -->
  <div class="hero-content">
    <h1 class="hero-title">DAO-YU-101</h1>
    <p class="hero-subtitle">Discover your island adventure</p>
    
    <div class="hero-buttons">
      <GameButton label="Store" />
      <GameButton label="Login" variant="secondary" />
      <GameButton label="Register" variant="secondary" />
    </div>
  </div>
</section>

<style>
  /* Import hero styles */
  @import '../styles/hero.css';
</style>

<script>
  // Mouse parallax effect for floating islands
  document.addEventListener('DOMContentLoaded', () => {
    const islandsContainer = document.getElementById('islands-container');
    
    // Check if mobile device
    if (window.innerWidth < 768) {
      return; // Disable parallax on mobile
    }

    if (islandsContainer) {
      // Use requestAnimationFrame for smooth animations
      let animationId: number;
      let mouseX = 0;
      let mouseY = 0;
      let isAnimating = false;

      islandsContainer.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
        
        if (!isAnimating) {
          isAnimating = true;
          animationId = requestAnimationFrame(updateParallax);
        }
      });

      islandsContainer.addEventListener('mouseleave', () => {
        cancelAnimationFrame(animationId);
        isAnimating = false;
        
        // Reset transform when mouse leaves
        const parallaxElements = islandsContainer.querySelectorAll('.parallax') as NodeListOf<HTMLElement>;
        parallaxElements.forEach(element => {
          element.style.transform = 'translate(0, 0)';
        });
      });

      function updateParallax() {
        if (!isAnimating) return;
        
        const { innerWidth, innerHeight } = window;
        
        // Calculate mouse position relative to center (-0.5 to 0.5)
        const x = (mouseX / innerWidth - 0.5);
        const y = (mouseY / innerHeight - 0.5);
        
        // Apply parallax effect to all parallax elements
        const parallaxElements = islandsContainer.querySelectorAll('.parallax') as NodeListOf<HTMLElement>;
        
        parallaxElements.forEach(element => {
          const depth = parseFloat(element.getAttribute('data-depth') || '0.5');
          
          // Calculate movement with depth factor (max 10px)
          const moveX = Math.max(-10, Math.min(10, x * 20 * depth));
          const moveY = Math.max(-10, Math.min(10, y * 20 * depth));
          
          element.style.transform = `translate(${moveX}px, ${moveY}px)`;
        });
        
        animationId = requestAnimationFrame(updateParallax);
      }
    }
  });
</script>
