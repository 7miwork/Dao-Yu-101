---
import VoxelTree from './island-details/VoxelTree.astro';
import VoxelRock from './island-details/VoxelRock.astro';
import VoxelHouse from './island-details/VoxelHouse.astro';

interface Props {
  id: string;
  x: number;
  y: number;
  z: number;
  scale?: number;
  className?: string;
  showDetails?: boolean;
  detailLevel?: 'foreground' | 'midground' | 'background';
}

const { id, x, y, z, scale = 1, className = '', showDetails = true, detailLevel = 'foreground' } = Astro.props;
---
<div class={`voxel-island ${className}`} style={`transform: translate3d(${x}px, ${y}px, ${z}px) scale(${scale})`}>
  <div class="grass-surface">
    {showDetails && detailLevel !== 'background' && (
      <>
        <VoxelTree  position="left"   size="medium" />
        <VoxelTree  position="right"  size="medium" />
        <VoxelHouse position="center" size="medium" />
        <VoxelRock  position="left"   size="small"  />
        <VoxelRock  position="right"  size="small"  />
      </>
    )}
  </div>
  <div class="dirt-layer-1"></div>
  <div class="dirt-layer-2"></div>
  <div class="dirt-layer-3"></div>
</div>
<style>
  .voxel-island {
    position: relative;
    width: 320px;
    height: 260px;
    margin: 0 auto;
    overflow: visible;
  }
  .grass-surface {
    position: relative;
    width: 320px;
    height: 40px;
    background: linear-gradient(to bottom, #7ed957 60%, #5da63e 100%);
    border-bottom: 5px solid #4a8c2e;
    overflow: visible;
    z-index: 3;
    margin-top: 120px;
  }
  .dirt-layer-1 { width: 320px; height: 55px; background: linear-gradient(to right, #7a4f22 0%, #8b5a2b 40%, #7a4f22 100%); margin: 0 auto; z-index: 2; }
  .dirt-layer-2 { width: 230px; height: 50px; background: linear-gradient(to right, #6b4019 0%, #7a4b24 40%, #6b4019 100%); margin: 0 auto; z-index: 2; }
  .dirt-layer-3 { width: 130px; height: 45px; background: linear-gradient(to right, #5c3414 0%, #6e4424 50%, #5c3414 100%); margin: 0 auto; border-radius: 0 0 4px 4px; z-index: 2; }
</style>