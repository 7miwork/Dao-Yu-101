---
import VoxelBlock from './VoxelBlock.astro';
import VoxelTree from './island-details/VoxelTree.astro';
import VoxelRock from './island-details/VoxelRock.astro';
import VoxelHouse from './island-details/VoxelHouse.astro';

interface Props {
  id: string;
  x: number;
  y: number;
  z: number;
  scale?: number;
  className?: string;
  showDetails?: boolean;
  detailLevel?: 'foreground' | 'midground' | 'background';
}

const { id, x, y, z, scale = 1, className = '', showDetails = true, detailLevel = 'foreground' } = Astro.props;

// Generate random seed for consistent detail placement
const seed = id.split('').reduce((a, b) => {
  a = ((a << 5) - a) + b.charCodeAt(0);
  return a & a;
}, 0);

function random(seed: number, min: number, max: number): number {
  const x = Math.sin(seed) * 10000;
  return Math.floor((x - Math.floor(x)) * (max - min + 1) + min);
}

// Determine detail count based on island level
let maxDetails = 3;
if (detailLevel === 'background') {
  maxDetails = 0;
} else if (detailLevel === 'midground') {
  maxDetails = 2;
}

// Mobile optimization: reduce detail count by 50%
const isMobile = typeof window !== 'undefined' && window.innerWidth < 768;
if (isMobile) {
  maxDetails = Math.floor(maxDetails * 0.5);
}

// Generate detail positions based on island position for consistency
const totalDetails = showDetails && maxDetails > 0 ? random(seed + x + y, 1, maxDetails) : 0;

const details = Array.from({ length: totalDetails }, (_, i) => {
  const type = random(seed + i, 0, 2);
  const positionOptions = ['left', 'center', 'right'];
  const sizeOptions = ['small', 'medium', 'large'];
  
  return {
    type: type === 0 ? 'tree' : type === 1 ? 'rock' : 'house',
    position: positionOptions[random(seed + i + 10, 0, 2)] as 'left' | 'center' | 'right',
    size: sizeOptions[random(seed + i + 20, 0, 2)] as 'small' | 'medium' | 'large',
    rotation: random(seed + i + 30, 0, 360)
  };
});
---

<div class="voxel-island {className}" style="transform: translate3d({x}px, {y}px, {z}px) scale({scale})">
  <!-- Top Layer: Grass (3x3 blocks) -->
  <VoxelBlock type="grass" size={20} className="island-top center" />
  <VoxelBlock type="grass" size={20} className="island-top left" />
  <VoxelBlock type="grass" size={20} className="island-top right" />
  <VoxelBlock type="grass" size={20} className="island-top front" />
  <VoxelBlock type="grass" size={20} className="island-top back" />
  
  <!-- Middle Layer: Dirt (5x5 blocks, tapered) -->
  <VoxelBlock type="dirt" size={20} className="island-dirt center" />
  <VoxelBlock type="dirt" size={20} className="island-dirt left" />
  <VoxelBlock type="dirt" size={20} className="island-dirt right" />
  <VoxelBlock type="dirt" size={20} className="island-dirt front" />
  <VoxelBlock type="dirt" size={20} className="island-dirt back" />
  <VoxelBlock type="dirt" size={20} className="island-dirt corner-1" />
  <VoxelBlock type="dirt" size={20} className="island-dirt corner-2" />
  <VoxelBlock type="dirt" size={20} className="island-dirt corner-3" />
  <VoxelBlock type="dirt" size={20} className="island-dirt corner-4" />
  
  <!-- Bottom Layer: Sand (7x7 blocks, wider base) -->
  <VoxelBlock type="sand" size={20} className="island-sand center" />
  <VoxelBlock type="sand" size={20} className="island-sand left" />
  <VoxelBlock type="sand" size={20} className="island-sand right" />
  <VoxelBlock type="sand" size={20} className="island-sand front" />
  <VoxelBlock type="sand" size={20} className="island-sand back" />
  <VoxelBlock type="sand" size={20} className="island-sand corner-1" />
  <VoxelBlock type="sand" size={20} className="island-sand corner-2" />
  <VoxelBlock type="sand" size={20} className="island-sand corner-3" />
  <VoxelBlock type="sand" size={20} className="island-sand corner-4" />
  <VoxelBlock type="sand" size={20} className="island-sand edge-1" />
  <VoxelBlock type="sand" size={20} className="island-sand edge-2" />
  <VoxelBlock type="sand" size={20} className="island-sand edge-3" />
  <VoxelBlock type="sand" size={20} className="island-sand edge-4" />
  
  <!-- Environmental Details -->
  {showDetails && maxDetails > 0 && (
    <>
      {details.map((detail, index) => {
        if (detail.type === 'tree') {
          return (
            <VoxelTree 
              position={detail.position}
              size={detail.size}
            />
          );
        } else if (detail.type === 'rock') {
          return (
            <VoxelRock 
              position={detail.position}
              size={detail.size}
            />
          );
        } else {
          return (
            <VoxelHouse 
              position={detail.position}
              size={detail.size}
            />
          );
        }
      })}
    </>
  )}
</div>

<style>
  .voxel-island {
    position: absolute;
    transform-style: preserve-3d;
    will-change: transform;
  }

  /* Positioning for stacked blocks */
  .voxel-island .voxel-block {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%) rotateX(60deg) rotateZ(45deg);
  }

  /* Layer positioning */
  .voxel-island .island-top {
    transform: translate(-50%, -50%) rotateX(60deg) rotateZ(45deg);
    z-index: 4;
  }

  .voxel-island .island-dirt {
    transform: translate(-50%, -50%) rotateX(60deg) rotateZ(45deg) translateY(20px);
    z-index: 3;
  }

  .voxel-island .island-sand {
    transform: translate(-50%, -50%) rotateX(60deg) rotateZ(45deg) translateY(40px);
    z-index: 2;
  }

  /* Block positioning within layers */
  .voxel-island .center { transform: translate(-50%, -50%) rotateX(60deg) rotateZ(45deg) translateY(0px); }
  .voxel-island .left { transform: translate(-65%, -50%) rotateX(60deg) rotateZ(45deg) translateY(0px); }
  .voxel-island .right { transform: translate(-35%, -50%) rotateX(60deg) rotateZ(45deg) translateY(0px); }
  .voxel-island .front { transform: translate(-50%, -65%) rotateX(60deg) rotateZ(45deg) translateY(0px); }
  .voxel-island .back { transform: translate(-50%, -35%) rotateX(60deg) rotateZ(45deg) translateY(0px); }
  
  .voxel-island .corner-1 { transform: translate(-65%, -65%) rotateX(60deg) rotateZ(45deg) translateY(0px); }
  .voxel-island .corner-2 { transform: translate(-35%, -65%) rotateX(60deg) rotateZ(45deg) translateY(0px); }
  .voxel-island .corner-3 { transform: translate(-65%, -35%) rotateX(60deg) rotateZ(45deg) translateY(0px); }
  .voxel-island .corner-4 { transform: translate(-35%, -35%) rotateX(60deg) rotateZ(45deg) translateY(0px); }
  
  .voxel-island .edge-1 { transform: translate(-80%, -50%) rotateX(60deg) rotateZ(45deg) translateY(0px); }
  .voxel-island .edge-2 { transform: translate(-20%, -50%) rotateX(60deg) rotateZ(45deg) translateY(0px); }
  .voxel-island .edge-3 { transform: translate(-50%, -80%) rotateX(60deg) rotateZ(45deg) translateY(0px); }
  .voxel-island .edge-4 { transform: translate(-50%, -20%) rotateX(60deg) rotateZ(45deg) translateY(0px); }
</style>

