---
import VoxelIsland from './VoxelIsland.astro';
import VoxelTree from './island-details/VoxelTree.astro';
import VoxelRock from './island-details/VoxelRock.astro';
import VoxelHouse from './island-details/VoxelHouse.astro';

interface Props {
  className?: string;
}

const { className = '' } = Astro.props;
---

<div class={`main-island ${className}`}>
  <!-- Main Voxel Island with details -->
  <VoxelIsland 
    id="main-island"
    x={0}
    y={0}
    z={0}
    scale={1.2}
    showDetails={true}
    detailLevel="foreground"
  />
</div>

<style>
  .main-island {
    position: relative;
    width: 420px;
    margin: 0 auto;
    animation: floatIsland 6s ease-in-out infinite;
    transform-origin: center;
    z-index: 5;
    top: 10%;
  }

  /* Floating Animation */
  @keyframes floatIsland {
    0% { transform: translateY(0); }
    50% { transform: translateY(-15px); }
    100% { transform: translateY(0); }
  }

  /* Responsive adjustments */
  @media (max-width: 1024px) {
    .main-island {
      width: 380px;
      transform: scale(1.1);
    }
  }

  @media (max-width: 768px) {
    .main-island {
      width: 320px;
      transform: scale(1.0);
    }
  }

  @media (max-width: 640px) {
    .main-island {
      width: 280px;
      transform: scale(0.9);
      top: 10%;
    }
  }

  @media (max-width: 480px) {
    .main-island {
      width: 240px;
      transform: scale(0.8);
    }
  }
</style>
