---
interface Props {
  position?: 'left' | 'center' | 'right';
  size?: 'small' | 'medium' | 'large';
}
const { position = 'center', size = 'medium' } = Astro.props;
const sizeMap = { small: 0.7, medium: 1, large: 1.3 };
const scale = sizeMap[size];
const trunkW = Math.round(10 * scale);
const trunkH = Math.round(28 * scale);
const leafW  = Math.round(28 * scale);
const leafH  = Math.round(22 * scale);
---
<div class={`voxel-tree pos-${position}`}>
  <div class="trunk" style={`width:${trunkW}px; height:${trunkH}px; bottom:0; left:${Math.round((leafW - trunkW) / 2)}px;`}></div>
  <div class="foliage" style={`width:${leafW}px; height:${leafH}px; bottom:${trunkH}px; left:0;`}></div>
</div>
<style>
  .voxel-tree { position: absolute; bottom: 0; z-index: 4; }
  .pos-left   { left: 18%; }
  .pos-center { left: 50%; transform: translateX(-50%); }
  .pos-right  { right: 18%; }
  .trunk {
    position: absolute;
    background: linear-gradient(to right, #6B3A1F 0%, #8B4513 40%, #5D3A1A 100%);
    border: 1.5px solid #3E2208;
    border-radius: 2px;
    box-shadow: inset -2px 0 4px rgba(0,0,0,0.3);
  }
  .foliage {
    position: absolute;
    background: linear-gradient(135deg, #56C34A 0%, #3A9E2F 50%, #2D7D24 100%);
    border: 1.5px solid #1E5C17;
    border-radius: 3px 3px 2px 2px;
    box-shadow: 2px 2px 6px rgba(0,0,0,0.35), inset 2px 2px 6px rgba(255,255,255,0.15);
  }
  .foliage::before {
    content: '';
    position: absolute;
    top: 3px; left: 3px;
    width: 35%; height: 35%;
    background: rgba(255,255,255,0.12);
    border-radius: 2px;
  }
</style>