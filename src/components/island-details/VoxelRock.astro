---
interface Props {
  position?: 'left' | 'center' | 'right';
  size?: 'small' | 'medium' | 'large';
}
const { position = 'center', size = 'small' } = Astro.props;
const sizeMap = { small: 0.7, medium: 1, large: 1.3 };
const scale = sizeMap[size];
const rockW = Math.round(18 * scale);
const rockH = Math.round(13 * scale);
---
<div class={`voxel-rock pos-${position}`} style={`width:${rockW}px; height:${rockH}px;`}>
  <div class="rock-body" style={`width:${rockW}px; height:${rockH}px;`}></div>
  <div class="pebble" style={`width:${Math.round(rockW*0.38)}px; height:${Math.round(rockH*0.55)}px; right:${Math.round(rockW*-0.2)}px;`}></div>
</div>
<style>
  .voxel-rock { position: absolute; bottom: 0; z-index: 4; }
  .pos-left   { left: 8%; }
  .pos-center { left: 50%; transform: translateX(-50%); }
  .pos-right  { right: 8%; }
  .rock-body {
    position: absolute;
    bottom: 0; left: 0;
    background: linear-gradient(135deg, #BDBDBD 0%, #9E9E9E 50%, #757575 100%);
    border: 1.5px solid #616161;
    border-radius: 3px 4px 2px 2px;
    box-shadow: 2px 2px 4px rgba(0,0,0,0.4), inset 2px 2px 4px rgba(255,255,255,0.15);
  }
  .rock-body::before {
    content: '';
    position: absolute;
    top: 2px; left: 2px;
    width: 40%; height: 35%;
    background: rgba(255,255,255,0.18);
    border-radius: 2px;
  }
  .pebble {
    position: absolute;
    bottom: 0;
    background: linear-gradient(135deg, #ABABAB 0%, #808080 100%);
    border: 1px solid #585858;
    border-radius: 2px 3px 2px 1px;
  }
</style>