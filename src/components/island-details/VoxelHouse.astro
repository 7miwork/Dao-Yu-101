---
interface Props {
  position?: 'left' | 'center' | 'right';
  size?: 'small' | 'medium' | 'large';
}
const { position = 'center', size = 'medium' } = Astro.props;
const sizeMap = { small: 0.7, medium: 1, large: 1.3 };
const scale = sizeMap[size];
const bodyW  = Math.round(36 * scale);
const bodyH  = Math.round(28 * scale);
const roofH  = Math.round(14 * scale);
const totalW = Math.round(bodyW * 1.15);
---
<div class={`voxel-house pos-${position}`} style={`width:${totalW}px;`}>
  <div class="house-body" style={`width:${bodyW}px; height:${bodyH}px; bottom:0; left:${Math.round((totalW - bodyW)/2)}px;`}>
    <div class="door" style={`width:${Math.round(bodyW*0.28)}px; height:${Math.round(bodyH*0.45)}px;`}></div>
    <div class="window win-l" style={`width:${Math.round(bodyW*0.2)}px; height:${Math.round(bodyH*0.22)}px;`}></div>
    <div class="window win-r" style={`width:${Math.round(bodyW*0.2)}px; height:${Math.round(bodyH*0.22)}px;`}></div>
  </div>
  <div class="house-roof" style={`width:${totalW}px; height:${roofH}px; bottom:${bodyH}px; left:0;`}></div>
</div>
<style>
  .voxel-house { position: absolute; bottom: 0; z-index: 4; }
  .pos-left   { left: 30%; }
  .pos-center { left: 50%; transform: translateX(-50%); }
  .pos-right  { right: 30%; }
  .house-body {
    position: absolute;
    background: linear-gradient(to right, #D4A574 0%, #C49060 50%, #A87850 100%);
    border: 1.5px solid #7A5035;
    border-radius: 1px;
    box-shadow: inset -3px 0 6px rgba(0,0,0,0.2);
  }
  .house-roof {
    position: absolute;
    background: linear-gradient(to right, #A52020 0%, #C0392B 40%, #8B1A1A 100%);
    border: 1.5px solid #5C0A0A;
    border-radius: 2px 2px 0 0;
    box-shadow: 2px 2px 5px rgba(0,0,0,0.4);
  }
  .house-roof::before {
    content: '';
    position: absolute;
    top: 2px; left: 3px;
    width: 40%; height: 40%;
    background: rgba(255,255,255,0.1);
    border-radius: 1px;
  }
  .door {
    position: absolute;
    bottom: 0; left: 50%;
    transform: translateX(-50%);
    background: #2F1B10;
    border: 1px solid #1A0F08;
    border-radius: 1px 1px 0 0;
  }
  .window { position: absolute; top: 20%; background: linear-gradient(135deg, #B0D8F0 0%, #4A90C4 100%); border: 1px solid #2060A0; border-radius: 1px; box-shadow: inset 1px 1px 3px rgba(0,0,0,0.3); }
  .win-l { left: 8%; }
  .win-r { right: 8%; }
</style>